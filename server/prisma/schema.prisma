generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Meeting {
  id          String       @id @default(cuid())
  title       String
  minutes     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  actionItems ActionItem[]
  decisions   Decision[]
  discussions Discussion[]
}

model ActionItem {
  id          String   @id @default(cuid())
  content     String
  sourceQuote String
  assignee    String?
  dueDate     DateTime?
  dueDateRaw  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Decision {
  id          String   @id @default(cuid())
  content     String
  sourceQuote String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}

model Discussion {
  id          String   @id @default(cuid())
  content     String
  sourceQuote String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
}
